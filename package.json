{
  "name": "SnDict",
  "version": "1.0.5",
  "description": "Tap or lasso a word on your Supernote and see its definition. Offline-first dictionary plugin with optional user-supplied dictionaries.",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "coverage": "jest --coverage",
    "fetch:dict": "node scripts/fetchBaseDict.mjs",
    "build:dict": "node scripts/buildBaseDict.mjs",
    "prepare:dict": "npm run --silent fetch:dict && npm run --silent build:dict",
    "build:sample-dicts": "node scripts/buildSampleDicts.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "pako": "^2.1.0",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "sn-plugin-lib": "^0.1.34"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "18.0.0",
    "@react-native-community/cli-platform-android": "18.0.0",
    "@react-native-community/cli-platform-ios": "18.0.0",
    "@react-native/babel-preset": "0.79.2",
    "@react-native/eslint-config": "0.79.2",
    "@react-native/metro-config": "0.79.2",
    "@react-native/typescript-config": "0.79.2",
    "@types/jest": "^29.5.13",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.0.0",
    "@types/react-test-renderer": "^19.0.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.0.0",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
